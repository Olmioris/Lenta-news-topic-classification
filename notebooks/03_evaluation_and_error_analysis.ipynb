from sklearn.metrics import classification_report
from collections import Counter

if grid_tfidf.best_score_ >= grid_count.best_score_:
    best_grid = grid_tfidf
else:
    best_grid = grid_count

best_model = best_grid.best_estimator_
best_model.fit(X_train_val, y_train_val)

y_test_pred = best_model.predict(X_test)
print("Test accuracy:", accuracy_score(y_test, y_test_pred))
print("Test macro F1:", f1_score(y_test, y_test_pred, average="macro"))
print(classification_report(y_test, y_test_pred))

errors_mask = y_test != y_test_pred
X_errors = X_test[errors_mask]
y_true_errors = y_test[errors_mask]
y_pred_errors = y_test_pred[errors_mask]

Counter(zip(y_true_errors, y_pred_errors)).most_common(10)
