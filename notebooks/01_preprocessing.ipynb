import re
from collections import Counter
import numpy as np
import pandas as pd

from corus import load_lenta
from pymorphy3 import MorphAnalyzer
import kagglehub
import os

RANDOM_STATE = 42
morph = MorphAnalyzer()

dataset_path = kagglehub.dataset_download(
    "yutkin/corpus-of-russian-news-articles-from-lenta"
)

csv_src = os.path.join(dataset_path, "lenta-ru-news.csv")
csv_dst = "/content/lenta-ru-news.csv"
gz_dst = "/content/lenta-ru-news.csv.gz"

records = load_lenta(gz_dst)

data = []
for index, record in enumerate(records):
    if index >= 100_000:
        break
    data.append(
        {"title": record.title, "text": record.text, "topic": record.topic}
    )

df = pd.DataFrame(data)
df = df[["text", "topic"]].dropna()
df["topic"] = df["topic"].astype("category")

def preprocess_text(text: str) -> str:
    text = text.lower()
    text = re.sub(r"[^а-яёa-z\s]", " ", text)
    text = re.sub(r"\s+", " ", text).strip()
    tokens = text.split()
    lemmas = [morph.parse(token)[0].normal_form for token in tokens]
    return " ".join(lemmas)

topic_counts = df["topic"].value_counts()
valid_topics = topic_counts[topic_counts >= 5].index
df = df[df["topic"].isin(valid_topics)].reset_index(drop=True)
df["text_clean"] = df["text"].apply(preprocess_text)
df = df[df["text_clean"].str.strip() != ""]
